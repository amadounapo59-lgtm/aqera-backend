# AQERA Backend (NestJS) environment
# Copy to .env and fill values. Required for dev + prod.
# Production: never commit .env; use platform secrets. Set AUTH_SECRET/JWT_SECRET to strong random values (e.g. openssl rand -base64 32).

# Server (bind 0.0.0.0 for Docker/LAN)
PORT=3000

# Database
# Dev (SQLite): file:./prisma/dev.db
# Prod (PostgreSQL): postgresql://user:pass@host:5432/dbname
DATABASE_URL="file:./prisma/dev.db"

# Auth (NestJS JWT + Passport)
# Used by auth.module (JwtModule). Fallback dev: "dev_secret_change_me"
AUTH_SECRET="change-me-in-production"

# JWT (legacy alias, optional if AUTH_SECRET set)
JWT_SECRET="change-me"

# Seed: admin compte créé au premier seed
ADMIN_EMAIL="admin@aqera.app"
ADMIN_PASSWORD="Admin123!"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs (create 2 products in Stripe: Brand Plans and Agency Plans)
STRIPE_PRICE_BRAND_STARTER="price_..."  # 79 CAD / month
STRIPE_PRICE_BRAND_PRO="price_..."      # 149 CAD / month
STRIPE_PRICE_BRAND_ELITE="price_..."    # 249 CAD / month

STRIPE_PRICE_AGENCY_STARTER="price_..." # 199 CAD / month
STRIPE_PRICE_AGENCY_PRO="price_..."     # 249 CAD / month
STRIPE_PRICE_AGENCY_ELITE="price_..."   # 499 CAD / month

# Optional: when Stripe redirects back to your web dashboard
WEBAPP_URL="http://localhost:3001"

# Pilot security (rate limits + audit, no email sending)
SECURITY_RATE_LIMIT_ENABLED=true
SECURITY_REGISTER_PER_IP_PER_HOUR=5
SECURITY_LOGIN_PER_IP_PER_15MIN=20
SECURITY_SUBMIT_PER_USER_PER_HOUR=40
SECURITY_REDEEM_PER_STAFF_PER_15MIN=60
SECURITY_PURCHASE_PER_USER_PER_DAY=10
SECURITY_REQUIRE_EMAIL_VERIFIED_FOR_PURCHASE=true
SECURITY_DEVICE_HEADER=x-device-id
SECURITY_AUDIT_LOG_ENABLED=true

# AI Suite (suggestions only; no auto-ban/auto-modify). When AI_ENABLED=false, fallback logic is used.
AI_ENABLED=true
AI_PROVIDER=openai
AI_MODEL=gpt-4.1-mini
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=900
# OpenAI API key (or AI_API_KEY)
OPENAI_API_KEY=sk-...
